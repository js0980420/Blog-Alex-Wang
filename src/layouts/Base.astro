---
import ogBanner from '../assets/banner-v2.png';
import PillButton from '../components/PillButton.astro';
import { NAV, LINKS, SITE, PERSON_SCHEMA } from '../consts';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  /** 頁面專屬的 JSON-LD（Article、Service、FAQPage 等），會與全站 Person 一起輸出 */
  schema?: object[];
  ogType?: string;
  /** 社群分享預覽圖，預設用全站橫幅 */
  ogImage?: string;
  /** og:image 的像素尺寸與替代文字；自訂 ogImage（文章橫幅固定 1200×630）時沿用預設即可 */
  ogImageWidth?: number;
  ogImageHeight?: number;
  ogImageAlt?: string;
}

const {
  title,
  description,
  schema = [],
  ogType = 'website',
  ogImage: pageOgImage,
  ogImageWidth = pageOgImage ? 1200 : ogBanner.width,
  ogImageHeight = pageOgImage ? 630 : ogBanner.height,
  ogImageAlt = title,
} = Astro.props;
const ogImage = pageOgImage ?? new URL(ogBanner.src, SITE.url).href;
const canonical = new URL(Astro.url.pathname, Astro.site);

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${SITE.url}/#website`,
      name: SITE.title,
      alternateName: [SITE.titleEn, 'aixwang'],
      url: SITE.url,
      description: SITE.description,
      inLanguage: SITE.locale,
      publisher: { '@id': PERSON_SCHEMA['@id'] },
    },
    PERSON_SCHEMA,
    ...schema,
  ],
};
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <!-- Google Analytics（GA4）流量統計：gtag.js 延到頁面載入完才注入，避免佔用首次渲染的主執行緒；
         事件在此之前先排入 dataLayer，載入後照樣送出 -->
    <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-91Z2F673C0');
      window.addEventListener('load', function () {
        var s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-91Z2F673C0';
        document.head.appendChild(s);
      });

      // 自訂事件：追蹤關鍵轉換點擊（LINE 諮詢 / Tooka / YouTube）
      document.addEventListener('click', function (e) {
        var a = e.target.closest && e.target.closest('a[href]');
        if (!a) return;
        var href = a.href || '';
        if (href.indexOf('line.me') !== -1) {
          gtag('event', 'line_click', { link_url: href, page_path: location.pathname });
        } else if (href.indexOf('/services/one-on-one') !== -1) {
          gtag('event', 'one_on_one_click', { link_url: href, page_path: location.pathname });
        } else if (href.indexOf('/services/speaking') !== -1) {
          gtag('event', 'speaking_click', { link_url: href, page_path: location.pathname });
        } else if (href.indexOf('tooka') !== -1) {
          gtag('event', 'tooka_click', { link_url: href, page_path: location.pathname });
        } else if (href.indexOf('youtube.com') !== -1 || href.indexOf('youtu.be') !== -1) {
          gtag('event', 'youtube_click', { link_url: href, page_path: location.pathname });
        }
      });
    </script>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <!-- 允許 Google 搜尋／Discover 使用大圖預覽 -->
    <meta name="robots" content="max-image-preview:large" />
    <link rel="icon" type="image/png" sizes="any" href="/favicon.png?v=2" />
    <link rel="shortcut icon" type="image/png" href="/favicon.png?v=2" />
    <link rel="apple-touch-icon" href="/aixwang-icon.png" />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="zh_TW" />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content={String(ogImageWidth)} />
    <meta property="og:image:height" content={String(ogImageHeight)} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="alternate" type="application/rss+xml" title={SITE.title} href="/rss.xml" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body
    class="min-h-screen bg-[#f7fbff] font-display text-slate-900 antialiased"
    style="background-image: radial-gradient(circle at 8% 0%, rgba(34, 211, 238, 0.12), transparent 28rem), radial-gradient(circle at 92% 12%, rgba(37, 99, 235, 0.08), transparent 32rem);"
  >
    <header class="fixed inset-x-0 top-0 z-50 border-b border-sky-100/80 bg-white/75 backdrop-blur-2xl">
      <div class="mx-auto flex max-w-6xl items-center justify-between gap-3 px-4 py-3 sm:px-6 sm:py-4">
        <a href="/" class="flex min-w-0 shrink items-center gap-2.5 sm:gap-3">
          <img
            src="/aixwang-icon.png"
            alt="aixwang"
            width="40"
            height="40"
            class="h-9 w-9 shrink-0 rounded-2xl object-cover sm:h-10 sm:w-10"
          />
          <div class="min-w-0">
            <div class="truncate text-base font-semibold tracking-tight text-[#101b4d] sm:text-lg">{SITE.title}</div>
            <div class="hidden text-[0.65rem] uppercase tracking-[0.18em] text-slate-500 sm:block">{SITE.titleEn}</div>
          </div>
        </a>
        <nav class="hidden items-center gap-6 text-sm text-slate-600 lg:flex">
          {NAV.map((item) => (
            <a href={item.href} class="transition hover:text-[#1688e8]">{item.label}</a>
          ))}
        </nav>
        <div class="flex shrink-0 items-center gap-3 sm:gap-4">
          <div id="search-container" class="relative">
            <button
              id="search-toggle"
              type="button"
              aria-label="開啟搜尋"
              aria-expanded="false"
              aria-controls="search-popover"
              class="flex h-9 w-9 items-center justify-center rounded-full text-slate-600 transition hover:bg-sky-50 hover:text-[#1688e8] lg:hidden"
            >
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="h-5 w-5" aria-hidden="true">
                <circle cx="11" cy="11" r="7" />
                <line x1="16.2" y1="16.2" x2="21" y2="21" />
              </svg>
            </button>
            <div
              id="search-popover"
              class="absolute right-0 top-full z-50 mt-3 hidden w-72 rounded-2xl border border-sky-100 bg-white p-3 shadow-xl lg:static lg:mt-0 lg:block lg:w-auto lg:border-0 lg:bg-transparent lg:p-0 lg:shadow-none"
            >
              <input
                id="site-search"
                type="search"
                aria-label="搜尋文章"
                autocomplete="off"
                class="w-full rounded-full border border-sky-200 bg-white/90 px-3 py-1.5 text-sm text-slate-700 outline-none transition-all focus:border-sky-400 lg:w-40 lg:focus:w-56"
              />
              <div id="search-examples" class="mt-3 lg:hidden">
                <div class="mb-1 px-2 text-xs text-slate-400">搜尋範例</div>
                <button type="button" data-search-example="新手要怎麼學 AI" data-search-query="AI 入門" class="block w-full rounded-xl px-2 py-1.5 text-left text-sm text-slate-600 hover:bg-sky-50">新手要怎麼學 AI</button>
                <button type="button" data-search-example="如何做自動發文" data-search-query="自動發文" class="block w-full rounded-xl px-2 py-1.5 text-left text-sm text-slate-600 hover:bg-sky-50">如何做自動發文</button>
                <button type="button" data-search-example="如何自動拍片" data-search-query="教學影片" class="block w-full rounded-xl px-2 py-1.5 text-left text-sm text-slate-600 hover:bg-sky-50">如何自動拍片</button>
              </div>
              <div
                id="search-results"
                class="mt-3 hidden max-h-80 w-full overflow-y-auto rounded-2xl border border-sky-100 bg-white p-2 shadow-xl lg:absolute lg:right-0 lg:top-full lg:w-80"
              ></div>
            </div>
          </div>
          <a
            href={LINKS.facebookGroup}
            target="_blank"
            rel="noreferrer"
            aria-label="Facebook 社團"
            class="hidden text-slate-500 transition hover:text-[#1688e8] lg:block"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
            </svg>
          </a>
          <a
            href={LINKS.threads}
            target="_blank"
            rel="noreferrer"
            aria-label="Threads 個人檔案"
            class="hidden text-slate-500 transition hover:text-[#1688e8] lg:block"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true">
              <path d="M12.186 24h-.007c-3.581-.024-6.334-1.205-8.184-3.509C2.35 18.44 1.5 15.586 1.472 12.01v-.017c.03-3.579.879-6.43 2.525-8.482C5.845 1.205 8.6.024 12.18 0h.014c2.746.02 5.043.725 6.826 2.098 1.677 1.29 2.858 3.13 3.509 5.467l-2.04.569c-1.104-3.96-3.898-5.984-8.304-6.015-2.91.022-5.11.936-6.54 2.717C4.307 6.504 3.616 8.914 3.589 12c.027 3.086.718 5.496 2.057 7.164 1.43 1.783 3.631 2.698 6.54 2.717 2.623-.02 4.358-.631 5.8-2.045 1.647-1.613 1.618-3.593 1.09-4.798-.31-.71-.873-1.3-1.634-1.75-.192 1.352-.622 2.446-1.284 3.272-.886 1.102-2.14 1.704-3.73 1.79-1.202.065-2.361-.218-3.259-.801-1.063-.689-1.685-1.74-1.752-2.964-.065-1.19.408-2.285 1.33-3.082.88-.76 2.119-1.207 3.583-1.291a13.853 13.853 0 0 1 3.02.142c-.126-.742-.375-1.332-.75-1.757-.513-.586-1.308-.883-2.359-.89h-.029c-.844 0-1.992.232-2.721 1.32L7.734 7.847c.98-1.454 2.568-2.256 4.478-2.256h.044c3.194.02 5.097 1.975 5.287 5.388.108.046.216.094.321.142 1.49.7 2.58 1.761 3.154 3.07.797 1.82.871 4.79-1.548 7.158-1.85 1.81-4.094 2.628-7.277 2.65Zm1.003-11.69c-.242 0-.487.007-.739.021-1.836.103-2.98.946-2.916 2.143.067 1.256 1.452 1.839 2.784 1.767 1.224-.065 2.818-.543 3.086-3.71a10.5 10.5 0 0 0-2.215-.221z" />
            </svg>
          </a>
          <a
            href={LINKS.youtube}
            target="_blank"
            rel="noreferrer"
            aria-label="YouTube 頻道"
            class="hidden text-slate-500 transition hover:text-[#1688e8] lg:block"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true">
              <path d="M23.498 6.186a3.003 3.003 0 0 0-2.112-2.123C19.505 3.5 12 3.5 12 3.5s-7.505 0-9.386.563A3.003 3.003 0 0 0 .502 6.186 31.3 31.3 0 0 0 0 12a31.3 31.3 0 0 0 .502 5.814 3.003 3.003 0 0 0 2.112 2.123C4.495 20.5 12 20.5 12 20.5s7.505 0 9.386-.563a3.003 3.003 0 0 0 2.112-2.123A31.3 31.3 0 0 0 24 12a31.3 31.3 0 0 0-.502-5.814ZM9.545 15.568V8.432L15.818 12l-6.273 3.568Z" />
            </svg>
          </a>
          <span class="hidden sm:block">
            <PillButton href={LINKS.line} variant="line" size="sm" external>免費諮詢</PillButton>
          </span>
          <button id="menu-toggle" type="button" aria-label="開啟選單" aria-expanded="false" class="text-slate-600 transition-transform duration-300 hover:text-[#1688e8] lg:hidden">
            <svg id="icon-burger" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="h-6 w-6" aria-hidden="true">
              <line x1="4" y1="6" x2="20" y2="6" />
              <line x1="4" y1="12" x2="20" y2="12" />
              <line x1="4" y1="18" x2="20" y2="18" />
            </svg>
            <svg id="icon-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="hidden h-6 w-6" aria-hidden="true">
              <line x1="6" y1="6" x2="18" y2="18" />
              <line x1="18" y1="6" x2="6" y2="18" />
            </svg>
          </button>
        </div>
      </div>
      <div id="mobile-menu" class="max-h-0 overflow-hidden bg-white/95 px-6 opacity-0 transition-[max-height,opacity,padding] duration-300 ease-in-out lg:hidden">
        <nav class="flex flex-col gap-1 text-slate-700">
          {NAV.map((item) => (
            <a href={item.href} class="rounded-xl px-3 py-2 transition hover:bg-sky-50 hover:text-[#1688e8]">{item.label}</a>
          ))}
        </nav>
        <div class="mt-4 flex items-center gap-5 border-t border-slate-100 px-3 pt-4">
          <a href={LINKS.line} target="_blank" rel="noreferrer" aria-label="LINE 免費諮詢" class="text-[#06c755] transition hover:opacity-80">
            <svg viewBox="0 0 24 24" fill="currentColor" class="h-6 w-6" aria-hidden="true">
              <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314" />
            </svg>
          </a>
          <a href={LINKS.facebookGroup} target="_blank" rel="noreferrer" aria-label="Facebook 社團" class="text-slate-500 transition hover:text-[#1688e8]">
            <svg viewBox="0 0 24 24" fill="currentColor" class="h-6 w-6" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
            </svg>
          </a>
          <a href={LINKS.threads} target="_blank" rel="noreferrer" aria-label="Threads 個人檔案" class="text-slate-500 transition hover:text-[#1688e8]">
            <svg viewBox="0 0 24 24" fill="currentColor" class="h-6 w-6" aria-hidden="true">
              <path d="M12.186 24h-.007c-3.581-.024-6.334-1.205-8.184-3.509C2.35 18.44 1.5 15.586 1.472 12.01v-.017c.03-3.579.879-6.43 2.525-8.482C5.845 1.205 8.6.024 12.18 0h.014c2.746.02 5.043.725 6.826 2.098 1.677 1.29 2.858 3.13 3.509 5.467l-2.04.569c-1.104-3.96-3.898-5.984-8.304-6.015-2.91.022-5.11.936-6.54 2.717C4.307 6.504 3.616 8.914 3.589 12c.027 3.086.718 5.496 2.057 7.164 1.43 1.783 3.631 2.698 6.54 2.717 2.623-.02 4.358-.631 5.8-2.045 1.647-1.613 1.618-3.593 1.09-4.798-.31-.71-.873-1.3-1.634-1.75-.192 1.352-.622 2.446-1.284 3.272-.886 1.102-2.14 1.704-3.73 1.79-1.202.065-2.361-.218-3.259-.801-1.063-.689-1.685-1.74-1.752-2.964-.065-1.19.408-2.285 1.33-3.082.88-.76 2.119-1.207 3.583-1.291a13.853 13.853 0 0 1 3.02.142c-.126-.742-.375-1.332-.75-1.757-.513-.586-1.308-.883-2.359-.89h-.029c-.844 0-1.992.232-2.721 1.32L7.734 7.847c.98-1.454 2.568-2.256 4.478-2.256h.044c3.194.02 5.097 1.975 5.287 5.388.108.046.216.094.321.142 1.49.7 2.58 1.761 3.154 3.07.797 1.82.871 4.79-1.548 7.158-1.85 1.81-4.094 2.628-7.277 2.65Zm1.003-11.69c-.242 0-.487.007-.739.021-1.836.103-2.98.946-2.916 2.143.067 1.256 1.452 1.839 2.784 1.767 1.224-.065 2.818-.543 3.086-3.71a10.5 10.5 0 0 0-2.215-.221z" />
            </svg>
          </a>
          <a href={LINKS.youtube} target="_blank" rel="noreferrer" aria-label="YouTube 頻道" class="text-slate-500 transition hover:text-[#1688e8]">
            <svg viewBox="0 0 24 24" fill="currentColor" class="h-6 w-6" aria-hidden="true">
              <path d="M23.498 6.186a3.003 3.003 0 0 0-2.112-2.123C19.505 3.5 12 3.5 12 3.5s-7.505 0-9.386.563A3.003 3.003 0 0 0 .502 6.186 31.3 31.3 0 0 0 0 12a31.3 31.3 0 0 0 .502 5.814 3.003 3.003 0 0 0 2.112 2.123C4.495 20.5 12 20.5 12 20.5s7.505 0 9.386-.563a3.003 3.003 0 0 0 2.112-2.123A31.3 31.3 0 0 0 24 12a31.3 31.3 0 0 0-.502-5.814ZM9.545 15.568V8.432L15.818 12l-6.273 3.568Z" />
            </svg>
          </a>
        </div>
      </div>
    </header>

    <script is:inline>
      (function () {
        // 漢堡選單（滑順展開收合）
        var btn = document.getElementById('menu-toggle');
        var menu = document.getElementById('mobile-menu');
        var iconBurger = document.getElementById('icon-burger');
        var iconClose = document.getElementById('icon-close');
        if (btn && menu) {
          btn.addEventListener('click', function () {
            var open = btn.getAttribute('aria-expanded') === 'true';
            if (open) {
              menu.style.maxHeight = '0';
              menu.classList.add('opacity-0');
              menu.classList.remove('border-t', 'border-slate-200', 'py-4');
            } else {
              menu.classList.add('border-t', 'border-slate-200', 'py-4');
              menu.classList.remove('opacity-0');
              menu.style.maxHeight = menu.scrollHeight + 40 + 'px';
            }
            btn.setAttribute('aria-expanded', String(!open));
            btn.setAttribute('aria-label', open ? '開啟選單' : '關閉選單');
            iconBurger.classList.toggle('hidden', !open);
            iconClose.classList.toggle('hidden', open);
            btn.style.transform = open ? '' : 'rotate(90deg)';
          });
        }

        // 全站搜尋
        var container = document.getElementById('search-container');
        var toggle = document.getElementById('search-toggle');
        var popover = document.getElementById('search-popover');
        var input = document.getElementById('site-search');
        var box = document.getElementById('search-results');
        var examples = document.getElementById('search-examples');
        var pagefind = null;
        var pagefindPromise = null;
        var fallbackIndex = null;
        var debounceTimer = null;
        var searchSequence = 0;
        var activeResult = -1;
        function isMobileSearch() {
          return window.matchMedia('(max-width: 1023px)').matches;
        }
        function openSearch() {
          if (!popover) return;
          popover.classList.remove('hidden');
          if (toggle) {
            toggle.setAttribute('aria-expanded', 'true');
            toggle.setAttribute('aria-label', '關閉搜尋');
          }
          window.setTimeout(function () { input && input.focus(); }, 0);
        }
        function closeSearch() {
          if (isMobileSearch() && popover) popover.classList.add('hidden');
          if (toggle) {
            toggle.setAttribute('aria-expanded', 'false');
            toggle.setAttribute('aria-label', '開啟搜尋');
          }
          if (box) box.classList.add('hidden');
        }
        function loadFallback() {
          if (fallbackIndex) return Promise.resolve(fallbackIndex);
          return fetch('/search-index.json')
            .then(function (r) { return r.json(); })
            .then(function (d) { fallbackIndex = d; return d; });
        }
        function loadPagefind() {
          if (pagefind) return Promise.resolve(pagefind);
          if (pagefindPromise) return pagefindPromise;
          pagefindPromise = new Function('return import("/pagefind/pagefind.js")')()
            .then(function (module) {
              pagefind = module;
              return pagefind.init().then(function () { return pagefind; });
            })
            .catch(function () {
              pagefind = null;
              pagefindPromise = null;
              return null;
            });
          return pagefindPromise;
        }
        function escapeHtml(value) {
          return String(value || '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;');
        }
        function render(list) {
          activeResult = list.length ? 0 : -1;
          if (!list.length) {
            box.innerHTML = '<div class="px-3 py-2 text-sm text-slate-400">沒有符合的文章</div>';
          } else {
            box.innerHTML = list
              .slice(0, 8)
              .map(function (item, index) {
                return '<a href="' + escapeHtml(item.u) + '" data-search-result="' + index + '" class="search-result-item block rounded-xl px-3 py-2 leading-5 text-slate-700 hover:bg-sky-50 ' + (index === 0 ? 'bg-sky-50' : '') + '">' +
                  '<span class="block text-sm font-medium">' + escapeHtml(item.t) + '</span>' +
                  (item.d ? '<span class="mt-1 block text-xs leading-5 text-slate-500">' + item.d + '</span>' : '') +
                  '</a>';
              })
              .join('');
          }
          box.classList.remove('hidden');
        }
        function renderLoading() {
          box.innerHTML = '<div class="px-3 py-2 text-sm text-slate-400">搜尋中…</div>';
          box.classList.remove('hidden');
        }
        function updateActiveResult() {
          box.querySelectorAll('.search-result-item').forEach(function (item, index) {
            item.classList.toggle('bg-sky-50', index === activeResult);
          });
        }
        function searchFallback(query, sequence) {
          return loadFallback().then(function (items) {
            if (sequence !== searchSequence) return;
            var q = query.toLowerCase();
            render(items
              .filter(function (item) {
                return (item.t + item.d + item.g).toLowerCase().indexOf(q) !== -1;
              })
              .map(function (item) {
                return { u: item.u, t: item.t, d: escapeHtml(item.d) };
              }));
          });
        }
        function executeSearch(query) {
          var sequence = ++searchSequence;
          renderLoading();
          loadPagefind().then(function (engine) {
            if (!engine) return searchFallback(query, sequence);
            return engine.search(query).then(function (search) {
              return Promise.all(search.results.slice(0, 8).map(function (result) {
                return result.data();
              }));
            }).then(function (results) {
              if (!results || sequence !== searchSequence) return;
              render(results.map(function (result) {
                return {
                  u: result.url,
                  t: result.meta && result.meta.title ? result.meta.title : result.url,
                  d: result.excerpt || '',
                };
              }));
            }).catch(function () {
              return searchFallback(query, sequence);
            });
          });
        }
        function searchFor(query, immediate) {
          var q = query.trim().toLowerCase();
          if (examples) examples.classList.toggle('hidden', !!q);
          window.clearTimeout(debounceTimer);
          if (!q) {
            searchSequence++;
            box.classList.add('hidden');
            return;
          }
          if (immediate) executeSearch(q);
          else debounceTimer = window.setTimeout(function () { executeSearch(q); }, 200);
        }
        if (toggle) {
          toggle.addEventListener('click', function () {
            var open = toggle.getAttribute('aria-expanded') === 'true';
            if (open) closeSearch();
            else openSearch();
          });
        }
        if (input && box) {
          input.addEventListener('focus', loadPagefind);
          input.addEventListener('input', function () {
            searchFor(input.value, false);
          });
          input.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') {
              closeSearch();
              if (toggle) toggle.focus();
              return;
            }
            var results = box.querySelectorAll('.search-result-item');
            if (e.key === 'ArrowDown') {
              e.preventDefault();
              if (results.length) {
                activeResult = Math.min(activeResult + 1, results.length - 1);
                updateActiveResult();
                results[activeResult].scrollIntoView({ block: 'nearest' });
              }
              return;
            }
            if (e.key === 'ArrowUp') {
              e.preventDefault();
              if (results.length) {
                activeResult = Math.max(activeResult - 1, 0);
                updateActiveResult();
                results[activeResult].scrollIntoView({ block: 'nearest' });
              }
              return;
            }
            if (e.key === 'Enter') {
              e.preventDefault();
              var a = results[activeResult] || results[0];
              if (a) location.href = a.getAttribute('href');
            }
          });
          if (examples) {
            examples.addEventListener('click', function (e) {
              var button = e.target.closest('[data-search-example]');
              if (!button) return;
              input.value = button.getAttribute('data-search-example') || '';
              searchFor(button.getAttribute('data-search-query') || input.value, true);
              input.focus();
            });
          }
          document.addEventListener('click', function (e) {
            if (container && !container.contains(e.target)) closeSearch();
          });
          document.addEventListener('keydown', function (e) {
            if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 'k') {
              e.preventDefault();
              openSearch();
            }
          });
        }
      })();
    </script>

    <main data-pagefind-body class="pt-28 lg:pt-20">
      <slot />
    </main>

    <footer class="mt-24 border-t border-slate-200 px-6 py-12">
      <div class="mx-auto grid max-w-6xl gap-8 md:grid-cols-3">
        <div>
          <div class="text-lg font-semibold">{SITE.title}</div>
          <p class="mt-3 max-w-xs text-sm leading-6 text-stone-400">
            {SITE.description}
          </p>
        </div>
        <div class="text-sm">
          <div class="mb-3 font-semibold text-stone-200">網站導覽</div>
          <ul class="space-y-2 text-stone-400">
            {NAV.map((item) => (
              <li><a href={item.href} class="hover:text-white">{item.label}</a></li>
            ))}
          </ul>
        </div>
        <div class="text-sm">
          <div class="mb-3 font-semibold text-stone-200">聯絡方式</div>
          <ul class="space-y-2 text-stone-400">
            <li><a href={LINKS.line} target="_blank" rel="noreferrer" class="hover:text-white">LINE 免費諮詢</a></li>
            <li><a href={LINKS.facebookGroup} target="_blank" rel="noreferrer" class="hover:text-white">Facebook 社團</a></li>
            <li><a href={LINKS.threads} target="_blank" rel="noreferrer" class="hover:text-white">Threads</a></li>
            <li><a href={LINKS.email} class="hover:text-white">Email 聯絡</a></li>
          </ul>
        </div>
      </div>
      <div class="mx-auto mt-10 flex max-w-6xl flex-wrap items-center gap-x-5 gap-y-2 border-t border-sky-100 pt-6 text-xs text-stone-500">
        <span>© {new Date().getFullYear()} {SITE.title} — AI 一對一私人教學與公開演講</span>
        <a href="/editorial-policy/" class="hover:text-[#1688e8]">編輯政策</a>
        <a href="/privacy/" class="hover:text-[#1688e8]">隱私權政策</a>
        <a href="/disclaimer/" class="hover:text-[#1688e8]">免責聲明</a>
      </div>
    </footer>
  </body>
</html>

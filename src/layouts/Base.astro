---
import ogBanner from '../assets/banner.png';
import PillButton from '../components/PillButton.astro';
import { NAV, LINKS, SITE, PERSON_SCHEMA } from '../consts';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  /** 頁面專屬的 JSON-LD（Article、Service、FAQPage 等），會與全站 Person 一起輸出 */
  schema?: object[];
  ogType?: string;
  /** 社群分享預覽圖，預設用全站橫幅 */
  ogImage?: string;
}

const {
  title,
  description,
  schema = [],
  ogType = 'website',
  ogImage = new URL(ogBanner.src, SITE.url).href,
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${SITE.url}/#website`,
      name: SITE.title,
      url: SITE.url,
      description: SITE.description,
      inLanguage: SITE.locale,
      publisher: { '@id': PERSON_SCHEMA['@id'] },
    },
    PERSON_SCHEMA,
    ...schema,
  ],
};
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <!-- Google Analytics（GA4）流量統計 -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-91Z2F673C0"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-91Z2F673C0');

      // 自訂事件：追蹤關鍵轉換點擊（LINE 諮詢 / Tooka / YouTube）
      document.addEventListener('click', function (e) {
        var a = e.target.closest && e.target.closest('a[href]');
        if (!a) return;
        var href = a.href || '';
        if (href.indexOf('line.me') !== -1) {
          gtag('event', 'line_click', { link_url: href, page_path: location.pathname });
        } else if (href.indexOf('/services/one-on-one') !== -1) {
          gtag('event', 'one_on_one_click', { link_url: href, page_path: location.pathname });
        } else if (href.indexOf('/services/speaking') !== -1) {
          gtag('event', 'speaking_click', { link_url: href, page_path: location.pathname });
        } else if (href.indexOf('tooka') !== -1) {
          gtag('event', 'tooka_click', { link_url: href, page_path: location.pathname });
        } else if (href.indexOf('youtube.com') !== -1 || href.indexOf('youtu.be') !== -1) {
          gtag('event', 'youtube_click', { link_url: href, page_path: location.pathname });
        }
      });
    </script>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" sizes="any" href="/favicon.png?v=2" />
    <link rel="shortcut icon" type="image/png" href="/favicon.png?v=2" />
    <link rel="apple-touch-icon" href="/aixwang-icon.png" />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="zh_TW" />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body
    class="min-h-screen bg-[#f7fbff] font-display text-slate-900 antialiased"
    style="background-image: radial-gradient(circle at 8% 0%, rgba(34, 211, 238, 0.12), transparent 28rem), radial-gradient(circle at 92% 12%, rgba(37, 99, 235, 0.08), transparent 32rem);"
  >
    <header class="fixed inset-x-0 top-0 z-50 border-b border-sky-100/80 bg-white/75 backdrop-blur-2xl">
      <div class="mx-auto flex max-w-6xl items-center justify-between gap-3 px-4 py-3 sm:px-6 sm:py-4">
        <a href="/" class="flex min-w-0 shrink items-center gap-2.5 sm:gap-3">
          <img
            src="/aixwang-icon.png"
            alt="aixwang"
            width="40"
            height="40"
            class="h-9 w-9 shrink-0 rounded-2xl object-cover sm:h-10 sm:w-10"
          />
          <div class="min-w-0">
            <div class="truncate text-base font-semibold tracking-tight text-[#101b4d] sm:text-lg">{SITE.title}</div>
            <div class="hidden text-[0.65rem] uppercase tracking-[0.18em] text-slate-500 sm:block">{SITE.titleEn}</div>
          </div>
        </a>
        <nav class="hidden items-center gap-6 text-sm text-slate-600 lg:flex">
          {NAV.map((item) => (
            <a href={item.href} class="transition hover:text-[#1688e8]">{item.label}</a>
          ))}
        </nav>
        <div class="flex shrink-0 items-center gap-3 sm:gap-4">
          <a
            href={LINKS.facebookGroup}
            target="_blank"
            rel="noreferrer"
            aria-label="Facebook 社團"
            class="hidden text-slate-500 transition hover:text-[#1688e8] md:block"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
            </svg>
          </a>
          <a
            href={LINKS.threads}
            target="_blank"
            rel="noreferrer"
            aria-label="Threads 個人檔案"
            class="hidden text-slate-500 transition hover:text-[#1688e8] md:block"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true">
              <path d="M12.186 24h-.007c-3.581-.024-6.334-1.205-8.184-3.509C2.35 18.44 1.5 15.586 1.472 12.01v-.017c.03-3.579.879-6.43 2.525-8.482C5.845 1.205 8.6.024 12.18 0h.014c2.746.02 5.043.725 6.826 2.098 1.677 1.29 2.858 3.13 3.509 5.467l-2.04.569c-1.104-3.96-3.898-5.984-8.304-6.015-2.91.022-5.11.936-6.54 2.717C4.307 6.504 3.616 8.914 3.589 12c.027 3.086.718 5.496 2.057 7.164 1.43 1.783 3.631 2.698 6.54 2.717 2.623-.02 4.358-.631 5.8-2.045 1.647-1.613 1.618-3.593 1.09-4.798-.31-.71-.873-1.3-1.634-1.75-.192 1.352-.622 2.446-1.284 3.272-.886 1.102-2.14 1.704-3.73 1.79-1.202.065-2.361-.218-3.259-.801-1.063-.689-1.685-1.74-1.752-2.964-.065-1.19.408-2.285 1.33-3.082.88-.76 2.119-1.207 3.583-1.291a13.853 13.853 0 0 1 3.02.142c-.126-.742-.375-1.332-.75-1.757-.513-.586-1.308-.883-2.359-.89h-.029c-.844 0-1.992.232-2.721 1.32L7.734 7.847c.98-1.454 2.568-2.256 4.478-2.256h.044c3.194.02 5.097 1.975 5.287 5.388.108.046.216.094.321.142 1.49.7 2.58 1.761 3.154 3.07.797 1.82.871 4.79-1.548 7.158-1.85 1.81-4.094 2.628-7.277 2.65Zm1.003-11.69c-.242 0-.487.007-.739.021-1.836.103-2.98.946-2.916 2.143.067 1.256 1.452 1.839 2.784 1.767 1.224-.065 2.818-.543 3.086-3.71a10.5 10.5 0 0 0-2.215-.221z" />
            </svg>
          </a>
          <a
            href={LINKS.youtube}
            target="_blank"
            rel="noreferrer"
            aria-label="YouTube 頻道"
            class="hidden text-slate-500 transition hover:text-[#1688e8] md:block"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true">
              <path d="M23.498 6.186a3.003 3.003 0 0 0-2.112-2.123C19.505 3.5 12 3.5 12 3.5s-7.505 0-9.386.563A3.003 3.003 0 0 0 .502 6.186 31.3 31.3 0 0 0 0 12a31.3 31.3 0 0 0 .502 5.814 3.003 3.003 0 0 0 2.112 2.123C4.495 20.5 12 20.5 12 20.5s7.505 0 9.386-.563a3.003 3.003 0 0 0 2.112-2.123A31.3 31.3 0 0 0 24 12a31.3 31.3 0 0 0-.502-5.814ZM9.545 15.568V8.432L15.818 12l-6.273 3.568Z" />
            </svg>
          </a>
          <PillButton href={LINKS.line} variant="line" size="sm" external>免費諮詢</PillButton>
        </div>
      </div>
      <nav class="flex gap-5 overflow-x-auto border-t border-slate-200 px-4 py-2.5 text-sm text-slate-600 sm:px-6 lg:hidden">
        {NAV.map((item) => (
          <a href={item.href} class="shrink-0 whitespace-nowrap transition hover:text-[#1688e8]">{item.label}</a>
        ))}
      </nav>
    </header>

    <main class="pt-28 lg:pt-20">
      <slot />
    </main>

    <footer class="mt-24 border-t border-slate-200 px-6 py-12">
      <div class="mx-auto grid max-w-6xl gap-8 md:grid-cols-3">
        <div>
          <div class="text-lg font-semibold">{SITE.title}</div>
          <p class="mt-3 max-w-xs text-sm leading-6 text-stone-400">
            {SITE.description}
          </p>
        </div>
        <div class="text-sm">
          <div class="mb-3 font-semibold text-stone-200">網站導覽</div>
          <ul class="space-y-2 text-stone-400">
            {NAV.map((item) => (
              <li><a href={item.href} class="hover:text-white">{item.label}</a></li>
            ))}
          </ul>
        </div>
        <div class="text-sm">
          <div class="mb-3 font-semibold text-stone-200">聯絡方式</div>
          <ul class="space-y-2 text-stone-400">
            <li><a href={LINKS.line} target="_blank" rel="noreferrer" class="hover:text-white">LINE 免費諮詢</a></li>
            <li><a href={LINKS.facebookGroup} target="_blank" rel="noreferrer" class="hover:text-white">Facebook 社團</a></li>
            <li><a href={LINKS.threads} target="_blank" rel="noreferrer" class="hover:text-white">Threads</a></li>
            <li><a href={LINKS.email} class="hover:text-white">Email 聯絡</a></li>
          </ul>
        </div>
      </div>
      <div class="mx-auto mt-10 max-w-6xl border-t border-sky-100 pt-6 text-xs text-stone-500">
        © {new Date().getFullYear()} {SITE.title} — AI 一對一私人教學與公開演講
      </div>
    </footer>
  </body>
</html>

---
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';
import Cta from '../../components/Cta.astro';
import FaqList from '../../components/FaqList.astro';
import { AUTHOR, SITE } from '../../consts';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, pubDate, updatedDate, faqs } = post.data;

const postUrl = `${SITE.url}/blog/${post.id}/`;
// 每篇文章使用已定案的 1200×630 靜態橫幅，檔名與 Directus slug 相同。
const postImage = new URL(`/images/blog/${post.id}.png`, SITE.url).href;
// 多長寬比 schema image（Google 文章富摘要建議的 16:9、4:3、1:1）與頁面用 WebP，
// 皆由 tools/optimize-blog-banners.mjs 從 PNG 自動衍生
const schemaImages = [
  new URL(`/images/blog/${post.id}-16x9.webp`, SITE.url).href,
  new URL(`/images/blog/${post.id}-4x3.webp`, SITE.url).href,
  new URL(`/images/blog/${post.id}-1x1.webp`, SITE.url).href,
];

// 文章目錄：從已渲染的 HTML 抽出 h2 錨點（id 由 content.config.ts 的 marked renderer 產生）
const toc = [...(post.rendered?.html ?? '').matchAll(/<h2 id="([^"]+)">(.*?)<\/h2>/g)].map(
  (m) => ({ id: m[1], text: m[2].replace(/<[^>]+>/g, '') }),
);
if (faqs.length > 0 && !toc.some((item) => item.id === 'faq')) {
  toc.push({ id: 'faq', text: 'FAQ 常見問題' });
}

const schema: object[] = [
  {
    '@type': 'BreadcrumbList',
    '@id': `${postUrl}#breadcrumb`,
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: '首頁', item: `${SITE.url}/` },
      { '@type': 'ListItem', position: 2, name: '部落格', item: `${SITE.url}/blog/` },
      { '@type': 'ListItem', position: 3, name: title },
    ],
  },
  {
    '@type': 'BlogPosting',
    '@id': `${postUrl}#article`,
    headline: title,
    description,
    inLanguage: 'zh-TW',
    datePublished: pubDate.toISOString(),
    dateModified: (updatedDate ?? pubDate).toISOString(),
    author: { '@id': AUTHOR.id },
    publisher: { '@id': AUTHOR.id },
    mainEntityOfPage: postUrl,
    image: schemaImages,
  },
];

if (faqs.length > 0) {
  schema.push({
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.question,
      acceptedAnswer: { '@type': 'Answer', text: f.answer },
    })),
  });
}

const dateText = pubDate.toLocaleDateString('zh-TW', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
// 發佈與更新時間並列顯示：時效訊號對搜尋結果點擊率有幫助
const updatedText = updatedDate
  ? updatedDate.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;
---

<Base
  title={`${title}｜${SITE.title}`}
  description={description}
  schema={schema}
  ogType="article"
  ogImage={postImage}
  noindex={post.data.unlisted}
>
  <article class="mx-auto max-w-3xl px-6 py-12">
    <nav aria-label="麵包屑" class="flex flex-wrap items-center gap-2 text-sm text-stone-400">
      <a href="/" class="hover:text-[#1688e8]">首頁</a>
      <span aria-hidden="true">›</span>
      <a href="/blog/" class="hover:text-[#1688e8]">部落格</a>
      <span aria-hidden="true">›</span>
      <span class="min-w-0 truncate text-stone-500">{title}</span>
    </nav>

    <header class="mt-8">
      <h1 class="text-3xl font-semibold leading-snug text-stone-50 md:text-4xl md:leading-snug">{title}</h1>
      <div class="mt-5 space-y-2.5 text-sm text-stone-400">
        <p>作者：<a href="/about/" class="text-stone-300 hover:text-white">{AUTHOR.name}</a></p>
        <p>
          <span class="inline-block rounded-full bg-sky-100 px-3 py-1">
            發佈於 <time datetime={pubDate.toISOString()}>{dateText}</time>
          </span>
        </p>
        {updatedText && (
          <p>
            <span class="inline-block rounded-full bg-amber-100 px-3 py-1">
              更新於 <time datetime={updatedDate!.toISOString()}>{updatedText}</time>
            </span>
          </p>
        )}
        <p class="flex flex-wrap gap-2">
          {post.data.tags.map((tag) => (
            <span class="rounded-full border border-sky-200 bg-sky-50 px-2.5 py-0.5 text-xs">{tag}</span>
          ))}
        </p>
      </div>

      <nav
        aria-label="文章目錄"
        class="mt-8 rounded-[1.75rem] border border-sky-200/80 bg-white/80 p-7 text-left shadow-[0_8px_30px_rgba(30,64,175,0.05)]"
      >
        <div class="text-lg font-semibold text-slate-900">目錄</div>
        <ol class="mt-4 space-y-2 text-[#1688e8]">
          {toc.map((item, i) => (
            <li class="flex gap-2 leading-7">
              <span class="text-stone-400">{i + 1}.</span>
              <a href={`#${item.id}`} class="underline-offset-4 hover:underline">{item.text}</a>
            </li>
          ))}
        </ol>
      </nav>

      <img
        src={`/images/blog/${post.id}.webp`}
        alt={title}
        width="1200"
        height="630"
        fetchpriority="high"
        class="mt-8 w-full rounded-[1.75rem] border border-sky-100 shadow-[0_8px_30px_rgba(30,64,175,0.06)]"
      />
    </header>

    <div class="prose-blog mt-10">
      <Content />
    </div>

    {faqs.length > 0 && (
      <section id="faq" class="mt-14 scroll-mt-24">
        <h2 class="mb-6 text-2xl font-semibold text-stone-50">FAQ 常見問題</h2>
        <FaqList faqs={faqs} />
      </section>
    )}

    <section class="mt-14 rounded-[1.75rem] border border-sky-200/80 bg-white/80 p-7 shadow-[0_8px_30px_rgba(30,64,175,0.05)]">
      <h2 class="text-lg font-semibold text-stone-50">關於作者</h2>
      <p class="mt-3 leading-7 text-stone-300/85">
        {AUTHOR.name}——{AUTHOR.description}
        <a href="/about/" class="text-amber-300 underline underline-offset-4">完整介紹</a>
      </p>
    </section>

    <Cta />
  </article>

  <script is:inline>
    // 幫每個程式碼區塊加上「複製」按鈕：指令類內容一鍵複製貼上
    (function () {
      function copyText(text) {
        if (navigator.clipboard && window.isSecureContext) {
          return navigator.clipboard.writeText(text);
        }
        var textarea = document.createElement('textarea');
        textarea.value = text;
        textarea.style.position = 'fixed';
        textarea.style.opacity = '0';
        document.body.appendChild(textarea);
        textarea.select();
        try {
          document.execCommand('copy');
          return Promise.resolve();
        } catch (e) {
          return Promise.reject(e);
        } finally {
          document.body.removeChild(textarea);
        }
      }

      document.querySelectorAll('.prose-blog pre').forEach(function (pre) {
        var wrapper = document.createElement('div');
        wrapper.className = 'code-block-wrapper';
        pre.parentNode.insertBefore(wrapper, pre);
        wrapper.appendChild(pre);

        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'copy-code-btn';
        btn.textContent = '複製';
        btn.setAttribute('aria-label', '複製程式碼');
        btn.addEventListener('click', function () {
          var text = pre.innerText.replace(/\n$/, '');
          copyText(text).then(
            function () {
              btn.textContent = '已複製 ✓';
              setTimeout(function () { btn.textContent = '複製'; }, 1500);
            },
            function () {
              btn.textContent = '複製失敗';
              setTimeout(function () { btn.textContent = '複製'; }, 1500);
            }
          );
        });
        wrapper.appendChild(btn);
      });
    })();
  </script>
</Base>

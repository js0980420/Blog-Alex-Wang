---
import { getCollection } from 'astro:content';
import Cta from '../../components/Cta.astro';
import PostCard from '../../components/PostCard.astro';
import Base from '../../layouts/Base.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
// 精選文章的顯示順序
const FEATURED_ORDER = [
  'how-to-start-learning-ai',
  'free-resources',
  'from-part-time-to-freelance',
  'why-i-built-tooka',
];
const featured = posts
  .filter((post) => post.data.featured)
  .sort((a, b) => FEATURED_ORDER.indexOf(a.id) - FEATURED_ORDER.indexOf(b.id));
const rest = posts.filter((post) => !post.data.featured);
---

<Base
  title="部落格｜AI 新手常見問題全解答"
  description="用問答形式解答新手學 AI 最常見的問題：Claude Code / Codex 怎麼選、Meta API 怎麼申請、自動發文怎麼做、Skill 是什麼。每篇文章直接回答一個你會問 AI 的問題。"
>
  <div class="mx-auto max-w-6xl px-6 py-12">
    <h1 class="text-3xl font-semibold text-slate-900 md:text-5xl">部落格</h1>
    <p class="mt-6 text-lg leading-8 text-slate-700">
      每篇文章回答一個新手學 AI 時最常問的問題——從工具選擇、Meta API 申請到自動發文與
      Skill 工作流。看完還有問題，歡迎<a href="/services/one-on-one/" class="text-amber-300 underline underline-offset-4">約一對一教學</a>。
    </p>
    {featured.length > 0 && (
      <>
        <h2 class="mt-12 text-xl font-semibold text-[#101b4d]">精選文章</h2>
        <div class="mt-6 grid grid-flow-col auto-cols-[minmax(220px,1fr)] gap-4 overflow-x-auto pb-3 xl:auto-cols-fr">
          {featured.map((post) => (
            <a
              href={`/blog/${post.id}/`}
              class="flex flex-col justify-between rounded-2xl border border-sky-200/80 bg-white/80 p-5 shadow-[0_8px_24px_rgba(30,64,175,0.05)] transition hover:border-sky-400 hover:shadow-[0_10px_28px_rgba(30,64,175,0.1)]"
            >
              <span class="text-xs uppercase tracking-wide text-sky-700">{post.data.tags[0]}</span>
              <h3 class="mt-3 text-sm font-semibold leading-6 text-slate-900">{post.data.title}</h3>
              <span class="mt-4 text-xs font-semibold text-[#1688e8]">閱讀全文 →</span>
            </a>
          ))}
        </div>
      </>
    )}
    <h2 class="mt-12 text-xl font-semibold text-slate-900">全部文章</h2>
    <div class="mt-6 grid gap-5">
      {rest.map((post) => <PostCard post={post} />)}
    </div>
    <Cta />
  </div>
</Base>

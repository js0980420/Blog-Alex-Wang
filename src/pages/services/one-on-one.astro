---
import { Image } from 'astro:assets';
import Card from '../../components/Card.astro';
import Cta from '../../components/Cta.astro';
import FaqList from '../../components/FaqList.astro';
import PillButton from '../../components/PillButton.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import TeachingTools from '../../components/TeachingTools.astro';
import { AUTHOR, LINKS, SITE } from '../../consts';
import { ONE_ON_ONE_FAQS } from '../../data/faqs';
import { CLASS_FORMATS, TEACHING_CASES, TEACHING_CONTENT, TEACHING_TOOLS } from '../../data/services';
import Base from '../../layouts/Base.astro';

const schema = [
  {
    '@type': 'Service',
    '@id': `${SITE.url}/services/one-on-one/#service`,
    name: 'AI 一對一私人教學',
    serviceType: 'AI 教學 / 一對一家教',
    description:
      '付費一對一 AI 私人教學：手把手帶零基礎學員完成桌面版 Claude Code / Codex、OpenClaw（龍蝦）、Hermes（愛馬仕）安裝、Meta API 串接與社群自動發文系統。雙北咖啡廳實體課或 Google Meet / Discord 線上課。',
    provider: { '@id': AUTHOR.id },
    areaServed: ['台北市', '新北市', '線上（台灣與海外皆可）'],
    availableChannel: [
      { '@type': 'ServiceChannel', name: '實體課（雙北咖啡廳）' },
      { '@type': 'ServiceChannel', name: '線上課（Google Meet / Discord）' },
    ],
  },
  {
    '@type': 'ItemList',
    '@id': `${SITE.url}/services/one-on-one/#cases`,
    name: '一對一教學實際案例',
    itemListElement: TEACHING_CASES.map((c, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: `${c.topic}｜學員背景：${c.student}`,
      description: c.description,
      image: new URL(c.image.src, SITE.url).href,
    })),
  },
  {
    '@type': 'ItemList',
    '@id': `${SITE.url}/services/one-on-one/#tools`,
    name: '可教學工具',
    itemListElement: TEACHING_TOOLS.map((t, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: t.note ? `${t.name}（${t.note}）` : t.name,
      image: new URL(t.image.src, SITE.url).href,
    })),
  },
  {
    '@type': 'FAQPage',
    mainEntity: ONE_ON_ONE_FAQS.map((f) => ({
      '@type': 'Question',
      name: f.question,
      acceptedAnswer: { '@type': 'Answer', text: f.answer },
    })),
  },
];
---

<Base
  title="AI 一對一私人教學｜雙北實體、線上皆可的付費私教"
  description="Alex 提供付費一對一 AI 私人教學：手把手帶你完成 Claude Code / Codex、OpenClaw（龍蝦）、Hermes（愛馬仕）安裝、Meta API 串接與自動發文系統。雙北咖啡廳實體課，或 Google Meet / Discord 線上課。"
  schema={schema}
>
  <div class="mx-auto max-w-4xl px-6 py-12">
    <h1 class="text-3xl font-semibold text-stone-50 md:text-5xl">AI 一對一私人教學</h1>

    <p class="mt-8 text-lg leading-9 text-stone-200/90">
      這是付費的一對一 AI 私人教學服務：由我（<a href="/about/" class="text-amber-300 underline underline-offset-4">{AUTHOR.name}</a>）手把手帶你，在<strong class="text-amber-200">你自己的電腦、你自己的帳號</strong>上，把
      AI 自動化流程真正跑通一次——從桌面版 Claude Code / Codex、OpenClaw（龍蝦）、Hermes（愛馬仕）安裝、Meta API 申請，到做出可排程的社群自動發文系統。
    </p>

    <SectionHeading size="md" class="mt-14">上課形式</SectionHeading>
    <div class="mt-6 grid gap-5 sm:grid-cols-2">
      {CLASS_FORMATS.map((format) => (
        <Card>
          <h3 class="text-xl font-semibold text-stone-50">{format.title}</h3>
          <p class="mt-3 leading-7 text-stone-300/85">{format.description}</p>
        </Card>
      ))}
    </div>

    <SectionHeading size="md" class="mt-14">教學內容</SectionHeading>
    <div class="mt-6 grid gap-5 sm:grid-cols-2">
      {TEACHING_CONTENT.map((item) => (
        <Card>
          <h3 class="text-xl font-semibold text-stone-50">{item.category}</h3>
          {item.logos && (
            <div class="mt-4 flex gap-2.5">
              {item.logos.map((logo) => (
                <Image src={logo.image} alt={logo.alt} width={96} class="h-9 w-9 rounded-lg object-cover" />
              ))}
            </div>
          )}
          <p class="mt-3 leading-7 text-stone-300/85">{item.detail}</p>
        </Card>
      ))}
    </div>

    <SectionHeading size="md" class="mt-14">可教學工具</SectionHeading>
    <TeachingTools />

    <SectionHeading size="md" class="mt-14">實際教學案例</SectionHeading>
    <p class="mt-4 leading-7 text-stone-300/85">
      以下是四個實際的一對一教學案例，涵蓋不同背景的學員與客製化主題：
    </p>
    <div class="mt-6 grid gap-5 sm:grid-cols-2">
      {TEACHING_CASES.map((item) => (
        <Card>
          <div class="flex items-center gap-3">
            <Image src={item.image} alt={item.imageAlt} width={96} class="h-10 w-10 shrink-0 rounded-xl object-contain" />
            <h3 class="text-lg font-semibold leading-snug text-stone-50">{item.topic}</h3>
          </div>
          <p class="mt-3 text-sm text-amber-200/80">學員背景：{item.student}</p>
          <p class="mt-3 leading-7 text-stone-300/85">{item.description}</p>
        </Card>
      ))}
    </div>

    <SectionHeading size="md" class="mt-14">常見問題</SectionHeading>
    <div class="mt-6">
      <FaqList faqs={ONE_ON_ONE_FAQS} />
    </div>

    <Cta
      centered
      title="想預約或先問問題？"
      text="加 LINE 告訴我你的目標和目前程度，我會建議適合的上課方式與堂數。"
    >
      <Fragment slot="actions">
        <PillButton href={LINKS.line} variant="line" external>LINE 免費諮詢</PillButton>
        <PillButton href={LINKS.email}>Email 聯絡</PillButton>
      </Fragment>
    </Cta>
  </div>
</Base>

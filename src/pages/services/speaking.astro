---
import { Image } from 'astro:assets';
import Card from '../../components/Card.astro';
import CheckItem from '../../components/CheckItem.astro';
import Cta from '../../components/Cta.astro';
import PillButton from '../../components/PillButton.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import TeachingTools from '../../components/TeachingTools.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { AUTHOR, LINKS, SITE, breadcrumbSchema } from '../../consts';
import {
  SPEAKING_ENGAGEMENTS,
  SPEAKING_FORMATS,
  SPEAKING_TOPICS,
  TEACHING_TOOLS,
} from '../../data/services';
import Base from '../../layouts/Base.astro';

const schema = [
  breadcrumbSchema([
    { name: '首頁', item: `${SITE.url}/` },
    { name: 'AI 演講與企業內訓' },
  ]),
  {
    '@type': 'Service',
    '@id': `${SITE.url}/services/speaking/#service`,
    name: 'AI 主題演講與企業內訓',
    serviceType: '公開演講 / 企業內訓 / 工作坊',
    description:
      'Alex 提供 AI 主題的公開演講、企業內訓與實作工作坊：AI Agent 入門、社群自動化、AI 影音內容生產等主題，曾受 MixerBox、TAIA 台灣人工智慧協會等單位邀請演講。',
    provider: { '@id': AUTHOR.id },
    areaServed: '雙北為主，外縣市有提供交通補助也可配合（實體）',
  },
  {
    '@type': 'ItemList',
    '@id': `${SITE.url}/services/speaking/#engagements`,
    name: '過往演講紀錄',
    itemListElement: SPEAKING_ENGAGEMENTS.map((e, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: `${e.host}｜${e.topic}`,
      description: e.description,
      image: new URL(e.image.src, SITE.url).href,
    })),
  },
  {
    '@type': 'ItemList',
    '@id': `${SITE.url}/services/speaking/#tools`,
    name: '可教學工具',
    itemListElement: TEACHING_TOOLS.map((t, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: t.note ? `${t.name}（${t.note}）` : t.name,
      image: new URL(t.image.src, SITE.url).href,
    })),
  },
];
---

<Base
  title="AI 演講邀約｜企業內訓、社群講座與實作工作坊"
  description="Alex 接受 AI 主題的演講與企業內訓邀約：AI Agent 入門、社群自動化、AI 一鍵拍片、AI 工作流設計。曾受 MixerBox、TAIA 台灣人工智慧協會邀請演講。實體以雙北為主，外縣市有提供交通補助也可配合。"
  schema={schema}
>
  <div class="mx-auto max-w-4xl px-6 py-12">
    <Breadcrumbs items={[{ name: '首頁', href: '/' }, { name: 'AI 演講與企業內訓' }]} class="mb-8" />
    <h1 class="text-3xl font-semibold text-stone-50 md:text-5xl">AI 演講與企業內訓邀約</h1>

    <p class="mt-8 text-lg leading-9 text-stone-200/90">
      我是 <a href="/about/" class="text-amber-300 underline underline-offset-4">{AUTHOR.name}</a>，接受企業、學校與社群的
      <strong class="text-amber-200">AI 主題演講、內訓與實作工作坊</strong>邀約。內容以「聽完就能動手」為原則：不談概念空話，現場直接演示
      AI Agent 如何完成真實任務。曾受 MixerBox、TAIA 台灣人工智慧協會等單位邀請演講。
    </p>

    <SectionHeading size="md" class="mt-14">可邀約的主題</SectionHeading>
    <div class="mt-6 grid gap-5 sm:grid-cols-2">
      {SPEAKING_TOPICS.map((topic) => (
        <Card>
          <h3 class="text-lg font-semibold text-stone-50">{topic.title}</h3>
          <p class="mt-3 leading-7 text-stone-300/85">{topic.description}</p>
        </Card>
      ))}
    </div>
    <p class="mt-6 leading-7 text-stone-300/85">
      以上主題皆可依聽眾背景（零基礎／行銷／工程）調整深度，也可以合併成半天或一天的實作工作坊。
    </p>

    <SectionHeading size="md" class="mt-14">可教學工具</SectionHeading>
    <TeachingTools />

    <SectionHeading size="md" class="mt-14">過往演講紀錄</SectionHeading>
    <div class="mt-6 grid gap-5 sm:grid-cols-2">
      {SPEAKING_ENGAGEMENTS.map((item) => (
        <Card padded={false} class="overflow-hidden">
          <Image src={item.image} alt={item.imageAlt} class="h-48 w-full object-cover" />
          <div class="p-7">
            <p class="text-xs uppercase tracking-[0.26em] text-amber-200/80">{item.host}</p>
            <h3 class="mt-3 text-lg font-semibold text-stone-50">{item.topic}</h3>
            <p class="mt-3 leading-7 text-stone-300/85">{item.description}</p>
            {item.link && (
              <a
                href={item.link}
                target="_blank"
                rel="noreferrer"
                class="mt-4 inline-block text-sm font-semibold text-amber-200/90 transition hover:text-amber-100"
              >
                {item.linkLabel}
              </a>
            )}
          </div>
        </Card>
      ))}
    </div>

    <SectionHeading size="md" class="mt-14">形式與地區</SectionHeading>
    <ul class="mt-6 space-y-4">
      {SPEAKING_FORMATS.map((item) => <CheckItem>{item}</CheckItem>)}
    </ul>

    <Cta
      centered
      title="邀約洽談"
      text="請提供活動日期、聽眾輪廓與希望的主題方向，我會盡快回覆可行性與報價。"
    >
      <Fragment slot="actions">
        <PillButton href={LINKS.line} variant="line" external>LINE 洽談</PillButton>
        <PillButton href={LINKS.email}>Email 聯絡</PillButton>
      </Fragment>
    </Cta>
  </div>
</Base>

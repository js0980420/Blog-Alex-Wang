---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import bannerImage from '../assets/banner.png';
import mixerboxTalkImage from '../assets/mixerbox-talk.jpeg';
import oneOnOneTeachingImage from '../assets/teaching-one-on-one.jpg';
import Card from '../components/Card.astro';
import CheckItem from '../components/CheckItem.astro';
import Cta from '../components/Cta.astro';
import FaqList from '../components/FaqList.astro';
import PillButton from '../components/PillButton.astro';
import PostCard from '../components/PostCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { AUTHOR, LINKS, SITE } from '../consts';
import { HOME_FAQS } from '../data/faqs';
import { AUDIENCE, OUTCOMES, SYLLABUS, VIDEOS } from '../data/home';
import { FEATURED_EXPERIENCE } from '../data/instructor';
import Base from '../layouts/Base.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

const schema = [
  {
    '@type': 'Course',
    '@id': `${SITE.url}/#course`,
    name: 'AI 新手實戰課：桌面版 Agent 與社群自動發文',
    description:
      '從桌面版 Claude Code / Codex 安裝、Meta 三大 API 串接、自動發文權限設定，到 Skill 工作流建立的零基礎 AI 實戰課程。提供一對一實體（雙北）與線上教學。',
    provider: { '@id': AUTHOR.id },
    inLanguage: 'zh-TW',
    courseMode: ['onsite', 'online'],
    teaches: SYLLABUS.map((s) => s.title),
  },
  {
    '@type': 'FAQPage',
    mainEntity: HOME_FAQS.map((f) => ({
      '@type': 'Question',
      name: f.question,
      acceptedAnswer: { '@type': 'Answer', text: f.answer },
    })),
  },
];
---

<Base
  title="AI新手教學｜零基礎學 Claude Code / Codex 與社群自動發文"
  description={SITE.description}
  schema={schema}
>
  <!-- Hero -->
  <section class="px-6 pt-8 md:pt-12">
    <div class="mx-auto max-w-6xl">
      <div class="overflow-hidden rounded-[2rem] border border-sky-200/80 bg-white shadow-[0_8px_30px_rgba(30,64,175,0.05)]">
        <Image src={bannerImage} alt="AI新手教學課程橫幅" class="h-auto w-full" loading="eager" />
      </div>
      <div class="mx-auto mt-12 max-w-3xl text-center">
        <h1 class="text-3xl font-semibold tracking-tight text-stone-50 md:text-5xl">
          零基礎也能做出自己的 AI 自動化系統
        </h1>
        <p class="mt-6 text-lg leading-8 text-stone-300/85">
          我是 {AUTHOR.name}，台灣的 AI 應用講師。我教零基礎新手使用 Claude Code、Codex
          等 AI Agent 工具，從安裝、Meta API 串接到社群自動發文，一步一步做出真正能執行的作品。提供
          <a href="/services/one-on-one/" class="text-amber-300 underline underline-offset-4">付費一對一私人教學</a>（雙北實體／線上）與
          <a href="/services/speaking/" class="text-amber-300 underline underline-offset-4">企業、社群演講</a>。
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <PillButton href={LINKS.line} variant="line" external>LINE 免費諮詢</PillButton>
          <PillButton href="/blog/">看部落格文章</PillButton>
        </div>
      </div>
    </div>
  </section>

  <!-- 課程介紹 -->
  <section id="overview" class="px-6 py-20">
    <div class="mx-auto max-w-6xl">
      <SectionHeading>課程介紹</SectionHeading>
      <div class="mt-5 max-w-3xl leading-8 text-stone-300/85">
        <p>
          這是學習一切 AI 自動化的基礎。無論你後續要學 AI 客服、AI 自動拍片、AI
          爬蟲，都需要先安裝桌面版 AI，取得 Agent 的工具權限，而不只是停留在網頁版對話；也要先設定好環境變數，讓 AI 可以跟第三方平台互動。
        </p>
        <p class="mt-4">
          如果你不想花錢，可以先看下方的免費教學影片；但因為還是很多人會卡關，所以我也提供手把手的一對一教學，可以約雙北咖啡廳上實體課，或用 Google Meet / Discord 線上上課。
        </p>
      </div>

      <div class="mt-12 grid gap-4 md:grid-cols-2">
        {OUTCOMES.map((item) => (
          <CheckItem as="div" iconClass="text-emerald-300">{item}</CheckItem>
        ))}
      </div>
    </div>
  </section>

  <!-- 課程大綱 -->
  <section id="syllabus" class="px-6 py-16">
    <div class="mx-auto max-w-6xl">
      <SectionHeading>課程大綱</SectionHeading>
      <p class="mt-4 max-w-3xl leading-8 text-stone-300/85">
        從桌面版 AI 安裝、Meta API 串接、發文權限設定，到 Skill 工作流建立，帶你一步一步做出真正能執行的 AI 自動化流程。每個模組都有對應的部落格文章可以先讀。
      </p>
      <div class="mt-10 grid gap-5 md:grid-cols-2">
        {SYLLABUS.map((item) => (
          <Card as="a" href={item.href} class="group transition hover:border-amber-300/25">
            <p class="text-xs uppercase tracking-[0.26em] text-amber-200/80">{item.label}</p>
            <h3 class="mt-3 text-xl font-semibold text-stone-50 md:text-2xl">{item.title}</h3>
            <p class="mt-4 leading-7 text-stone-300/80">{item.summary}</p>
            <span class="mt-4 inline-block text-sm font-semibold text-amber-300">閱讀對應文章 →</span>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- 適合對象 -->
  <section class="px-6 py-16">
    <div class="mx-auto max-w-6xl">
      <SectionHeading>適合誰來學？</SectionHeading>
      <div class="mt-10 grid gap-5 md:grid-cols-3">
        {AUDIENCE.map((item) => (
          <Card>
            <h3 class="text-xl font-semibold text-stone-50">{item.title}</h3>
            <p class="mt-3 leading-7 text-stone-300/80">{item.description}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- 講師介紹 -->
  <section id="instructor" class="px-6 py-16">
    <div class="mx-auto max-w-6xl">
      <SectionHeading>講師介紹</SectionHeading>
      <div class="mt-10 grid gap-8 lg:grid-cols-2">
        <div>
          <h3 class="text-2xl font-semibold text-stone-50">{AUTHOR.name}</h3>
          <p class="mt-2 text-amber-200">{AUTHOR.jobTitle}</p>
          <p class="mt-4 leading-8 text-stone-300/85">{AUTHOR.description}</p>
          <ul class="mt-6 grid gap-3 sm:grid-cols-2">
            {FEATURED_EXPERIENCE.map((item) => <CheckItem>{item.text}</CheckItem>)}
          </ul>
          <a href="/about/" class="mt-6 inline-block text-sm font-semibold text-amber-300">完整講師介紹 →</a>
        </div>
        <div class="grid gap-5">
          <figure class="overflow-hidden rounded-[1.75rem] border border-sky-200/80 bg-white/80 shadow-[0_8px_30px_rgba(30,64,175,0.05)]">
            <Image src={oneOnOneTeachingImage} alt="一對一實體教學現場" class="h-64 w-full object-cover" />
            <figcaption class="border-t border-sky-100 bg-white px-5 py-3 text-sm text-stone-300">一對一實體教學現場</figcaption>
          </figure>
          <figure class="overflow-hidden rounded-[1.75rem] border border-sky-200/80 bg-white/80 shadow-[0_8px_30px_rgba(30,64,175,0.05)]">
            <Image src={mixerboxTalkImage} alt="Mixerbox 講座授課紀錄" class="h-64 w-full object-cover" />
            <figcaption class="border-t border-sky-100 bg-white px-5 py-3 text-sm text-stone-300">Mixerbox 講座合作紀錄</figcaption>
          </figure>
        </div>
      </div>
    </div>
  </section>

  <!-- 教學影片 -->
  <section id="videos" class="px-6 py-16">
    <div class="mx-auto max-w-6xl">
      <SectionHeading>免費教學影片</SectionHeading>
      <p class="mt-4 max-w-3xl leading-8 text-stone-300/85">如果你不想花錢，可在此看免費教學，或是課後用來複習。</p>
      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        {VIDEOS.map((video) => (
          <Card as="article" padded={false} class="overflow-hidden">
            <div class="aspect-video w-full bg-black">
              {video.embedId ? (
                <iframe
                  class="h-full w-full"
                  src={`https://www.youtube-nocookie.com/embed/${video.embedId}`}
                  title={video.title}
                  loading="lazy"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                  referrerpolicy="strict-origin-when-cross-origin"
                  allowfullscreen
                />
              ) : (
                <video class="h-full w-full" src={video.src} controls preload="metadata" playsinline />
              )}
            </div>
            <div class="p-6">
              <span class="rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-xs uppercase tracking-wide text-stone-300">{video.tag}</span>
              <h3 class="mt-4 text-xl font-semibold text-stone-50">{video.title}</h3>
              <p class="mt-3 leading-7 text-stone-300/80">{video.description}</p>
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- 最新文章 -->
  <section class="px-6 py-16">
    <div class="mx-auto max-w-6xl">
      <div class="flex items-end justify-between gap-4">
        <SectionHeading>最新文章</SectionHeading>
        <a href="/blog/" class="text-sm font-semibold text-amber-300">所有文章 →</a>
      </div>
      <div class="mt-10 grid gap-5 md:grid-cols-2">
        {posts.map((post) => <PostCard post={post} />)}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="px-6 py-16">
    <div class="mx-auto max-w-4xl">
      <SectionHeading>常見問題</SectionHeading>
      <div class="mt-10">
        <FaqList faqs={HOME_FAQS} />
      </div>
      <Cta />
    </div>
  </section>
</Base>

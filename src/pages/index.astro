---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import Card from '../components/Card.astro';
import Cta from '../components/Cta.astro';
import FaqList from '../components/FaqList.astro';
import PillButton from '../components/PillButton.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { AUTHOR, LINKS, SITE, pageBannerUrl } from '../consts';
import { HOME_FAQS } from '../data/faqs';
import { SYLLABUS, VIDEOS } from '../data/home';
import {
  SPEAKING_ENGAGEMENTS,
  TEACHING_CASES,
  TEACHING_CONTENT,
} from '../data/services';
import Base from '../layouts/Base.astro';

const allPosts = (await getCollection('blog', ({ data }) => !data.unlisted)).sort(
  (a, b) =>
    b.data.pubDate.valueOf() - a.data.pubDate.valueOf() ||
    (b.data.cmsId ?? 0) - (a.data.cmsId ?? 0),
);

// 精選文章的顯示順序（與部落格列表一致）
const FEATURED_ORDER = [
  'how-to-start-learning-ai',
  'free-resources',
  'from-part-time-to-freelance',
  'why-i-built-tooka',
  'threads-api-tutorial',
  'instagram-api-tutorial',
];
const featured = allPosts
  .filter((post) => post.data.featured)
  .sort((a, b) => FEATURED_ORDER.indexOf(a.id) - FEATURED_ORDER.indexOf(b.id));

const schema = [
  {
    '@type': 'Course',
    '@id': `${SITE.url}/#course`,
    name: 'AI 新手實戰課：桌面版 Agent 與社群自動發文',
    description:
      '從桌面版 Claude Code / Codex 安裝、Meta 三大 API 串接、自動發文權限設定，到 Skill 工作流建立的零基礎 AI 實戰課程。提供一對一實體（雙北）與線上教學。',
    provider: { '@id': AUTHOR.id },
    inLanguage: 'zh-TW',
    courseMode: ['onsite', 'online'],
    teaches: SYLLABUS.map((s) => s.title),
  },
  {
    '@type': 'FAQPage',
    mainEntity: HOME_FAQS.map((f) => ({
      '@type': 'Question',
      name: f.question,
      acceptedAnswer: { '@type': 'Answer', text: f.answer },
    })),
  },
];
---

<Base
  title="AI新手教學｜零基礎學 Claude Code / Codex 與社群自動發文"
  description={SITE.description}
  ogImage={pageBannerUrl('home')}
  ogImageAlt="AI 新手教學｜從工具到自動化"
  schema={schema}
>
  <!-- 區塊一：加 LINE 描述需求（免費優先） -->
  <section class="px-6 pt-8 md:pt-16">
    <div class="mx-auto max-w-6xl">
      <div class="mx-auto max-w-3xl text-center">
        <h1 class="text-2xl font-semibold leading-snug tracking-tight text-slate-900 md:text-5xl md:leading-snug">
          AI 工具很多，不知道哪個適合你？我提供免費諮詢
        </h1>
        <p class="mt-4 text-base leading-7 text-slate-700 md:mt-6 md:text-lg md:leading-8">
          我是 {AUTHOR.name}——AI 講師、全職接案工程師、全台最大龍蝦（OpenClaw）社團版主（21
          萬人）。我教你 <strong>4 大 AI Agent 的安裝使用、生圖、拍片</strong>，以及<strong>讓 AI 跟你的社群軟體互動的 API 串接</strong>——例如用 LINE 跟 AI 對話，整理其他平台的訊息——全部打包成「對話就能完成」的工作流，<strong>一次學習，多次受用</strong>。
        </p>
        <div class="mt-6 flex flex-wrap justify-center gap-3 md:mt-8">
          <PillButton href={LINKS.line} variant="line" external>LINE 免費諮詢</PillButton>
          <PillButton href="/blog/free-resources/">先看免費資源</PillButton>
        </div>
        <p class="mt-5 text-sm leading-6 text-slate-500 md:text-base md:leading-7">
          加 LINE 描述需求：<a href="/blog/free-resources/" class="text-[#1688e8] underline underline-offset-4">免費文章、影片</a>有提到的內容<strong>完全免費</strong>；想有人手把手帶著學，再考慮<a href="/services/one-on-one/" class="text-[#1688e8] underline underline-offset-4">實體或線上一對一</a>。
        </p>
      </div>
    </div>
  </section>

  <!-- 區塊二：我的免費資源 -->
  <section id="free-resources" class="px-6 py-20">
    <div class="mx-auto max-w-6xl">
      <div class="flex items-end justify-between gap-4">
        <SectionHeading>我的免費資源</SectionHeading>
        <a href="/blog/free-resources/" class="text-sm font-semibold text-[#1688e8]">全部免費資源 →</a>
      </div>
      <p class="mt-4 max-w-3xl leading-8 text-slate-700">
        教學影片照著做就能跑通；開源工具 Tooka 做社群圖文＋一鍵發佈。卡關了再來找我就好。
      </p>
      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        {VIDEOS.map((video) => (
          <Card as="article" padded={false} class="overflow-hidden">
            <div class="aspect-video w-full bg-black">
              {video.embedId ? (
                <iframe
                  class="h-full w-full"
                  src={`https://www.youtube-nocookie.com/embed/${video.embedId}`}
                  title={video.title}
                  loading="lazy"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                  referrerpolicy="strict-origin-when-cross-origin"
                  allowfullscreen
                />
              ) : (
                <video class="h-full w-full" src={video.src} controls preload="metadata" playsinline />
              )}
            </div>
            <div class="p-6">
              <span class="rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-xs uppercase tracking-wide text-slate-600">{video.tag}</span>
              <h3 class="mt-4 text-xl font-semibold text-slate-900">{video.title}</h3>
              <p class="mt-3 leading-7 text-slate-600">{video.description}</p>
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- 區塊三：一對一教學經歷 -->
  <section id="teaching-cases" class="px-6 py-16">
    <div class="mx-auto max-w-6xl">
      <div class="flex items-end justify-between gap-4">
        <SectionHeading>一對一教學經歷</SectionHeading>
        <a href="/services/one-on-one/" class="text-sm font-semibold text-[#1688e8]">一對一教學詳情 →</a>
      </div>
      <p class="mt-4 max-w-3xl leading-8 text-slate-700">
        實際帶過的一對一教學案例——從工程師到完全非技術背景的學員都有。
      </p>
      <div class="mt-10 grid gap-5 md:grid-cols-2">
        {TEACHING_CASES.map((item) => (
          <Card>
            <div class="flex items-center gap-3">
              <Image src={item.image} alt={item.imageAlt} class="h-10 w-10 rounded-xl object-contain" />
              <p class="text-xs uppercase tracking-[0.26em] text-sky-700">{item.student}</p>
            </div>
            <h3 class="mt-3 text-lg font-semibold text-slate-900">{item.topic}</h3>
            <p class="mt-3 leading-7 text-slate-600">{item.description}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- 區塊四：公眾演講經歷 -->
  <section id="speaking" class="px-6 py-16">
    <div class="mx-auto max-w-6xl">
      <div class="flex items-end justify-between gap-4">
        <SectionHeading>公眾演講經歷</SectionHeading>
        <a href="/services/speaking/" class="text-sm font-semibold text-[#1688e8]">演講邀約詳情 →</a>
      </div>
      <div class="mt-10 grid gap-5 md:grid-cols-2">
        {SPEAKING_ENGAGEMENTS.map((item) => (
          <Card padded={false} class="overflow-hidden">
            <Image src={item.image} alt={item.imageAlt} class="h-48 w-full object-cover" />
            <div class="p-6">
              <p class="text-xs uppercase tracking-[0.26em] text-sky-700">{item.host}</p>
              <h3 class="mt-3 text-lg font-semibold text-slate-900">{item.topic}</h3>
              <p class="mt-3 leading-7 text-slate-600">{item.description}</p>
              {item.link && (
                <a href={item.link} target="_blank" rel="noreferrer" class="mt-4 inline-block text-sm font-semibold text-[#1688e8]">
                  {item.linkLabel}
                </a>
              )}
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- 區塊五：我主要的教學內容 -->
  <section id="teaching-content" class="px-6 py-16">
    <div class="mx-auto max-w-6xl">
      <SectionHeading>我主要的教學內容</SectionHeading>
      <p class="mt-4 max-w-3xl leading-8 text-slate-700">
        想系統性學完整流程，可以看<a href="/blog/first-ai-lesson/" class="text-[#1688e8] underline underline-offset-4">新手學 AI 的第一堂課（完整課綱）</a>。
      </p>
      <div class="mt-10 grid gap-5 md:grid-cols-2">
        {TEACHING_CONTENT.map((item) => (
          <Card>
            <h3 class="text-xl font-semibold text-slate-900">{item.category}</h3>
            <p class="mt-3 leading-7 text-slate-600">{item.detail}</p>
            {item.logos && (
              <div class="mt-4 flex items-center gap-3">
                {item.logos.map((logo) => (
                  <Image src={logo.image} alt={logo.alt} class="h-8 w-8 rounded-lg object-contain" />
                ))}
              </div>
            )}
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- 區塊六：精選文章 -->
  <section id="featured" class="px-6 py-16">
    <div class="mx-auto max-w-6xl">
      <div class="flex items-end justify-between gap-4">
        <SectionHeading>精選文章</SectionHeading>
        <a href="/blog/" class="text-sm font-semibold text-[#1688e8]">所有文章 →</a>
      </div>
      <p class="mt-4 max-w-3xl leading-8 text-slate-700">從零基礎入門路線、免費資源到我的轉職故事——先從這幾篇開始讀。</p>
      <div class="mt-10 grid grid-cols-2 gap-4 lg:grid-cols-4">
        {featured.map((post) => (
          <a
            href={`/blog/${post.id}/`}
            class="flex flex-col justify-between rounded-2xl border border-sky-200/80 bg-white/80 p-5 shadow-[0_8px_24px_rgba(30,64,175,0.05)] transition hover:border-sky-400 hover:shadow-[0_10px_28px_rgba(30,64,175,0.1)]"
          >
            <span class="text-xs uppercase tracking-wide text-sky-700">{post.data.tags[0]}</span>
            <h3 class="mt-3 text-sm font-semibold leading-6 text-slate-900">{post.data.title}</h3>
            <span class="mt-4 text-xs font-semibold text-[#1688e8]">閱讀全文 →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 區塊七：一對一教學 FAQ -->
  <section id="faq" class="px-6 py-16">
    <div class="mx-auto max-w-4xl">
      <SectionHeading>一對一教學常見問題</SectionHeading>
      <div class="mt-10">
        <FaqList faqs={HOME_FAQS} />
      </div>
      <Cta />
    </div>
  </section>
</Base>

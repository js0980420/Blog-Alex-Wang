---
import { Image } from 'astro:assets';
import taichungLectureImage from '../assets/taichung-lecture.jpg';
import tookaCoverImage from '../assets/tooka-cover.jpg';
import CheckItem from '../components/CheckItem.astro';
import Cta from '../components/Cta.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { AUTHOR, SITE, breadcrumbSchema } from '../consts';
import { EXPERIENCE } from '../data/instructor';
import Base from '../layouts/Base.astro';

const schema = [
  breadcrumbSchema([{ name: '首頁', item: `${SITE.url}/` }, { name: '關於講師' }]),
];
---

<Base
  title={`關於講師 ${AUTHOR.name}｜AI 應用講師、一對一教學與演講`}
  description={AUTHOR.description}
  ogType="profile"
  schema={schema}
>
  <div class="mx-auto max-w-4xl px-6 py-12">
    <Breadcrumbs items={[{ name: '首頁', href: '/' }, { name: '關於講師' }]} class="mb-8" />
    <h1 class="text-3xl font-semibold text-stone-50 md:text-5xl">關於講師 {AUTHOR.name}</h1>

    <p class="mt-8 text-lg leading-9 text-stone-200/90">
      {AUTHOR.name}（本名王士麟，英文名 Alex Wang，網路上也叫艾克斯王）是 AI 講師，也是全職接案工程師與 21 萬人 OpenClaw 中文社群的版主。我教 AI Agent 工具使用、做自動發文、AI 生圖模板、對話式拍片——把工作流程簡化成對話就能完成，只需第一次使用前的安裝、串接成本，一次性教學，受用好幾次。目前提供<strong class="text-amber-200">付費一對一私人教學</strong>（雙北實體或線上）與<strong class="text-amber-200">企業、學校、社群的公開演講</strong>。我沒進過軟體業，是靠 AI 一步一步自學到全職接案的——完整過程寫在<a href="/blog/from-part-time-to-freelance/" class="text-amber-300 underline underline-offset-4 hover:text-amber-200">我的轉職故事</a>。
    </p>

    <figure class="mt-10 overflow-hidden rounded-[1.75rem] border border-sky-200/80 bg-white/80 shadow-[0_8px_30px_rgba(30,64,175,0.05)]">
      <Image
        src={taichungLectureImage}
        alt={`AI 講師 ${AUTHOR.name} 台中場「AI 製作社群貼文」講座授課現場`}
        class="w-full object-cover"
      />
    </figure>

    <SectionHeading size="md" class="mt-14">代表作品：Tooka</SectionHeading>
    <div class="mt-6 overflow-hidden rounded-[1.75rem] border border-sky-200/80 bg-white/80 shadow-[0_8px_30px_rgba(30,64,175,0.05)]">
      <a href="https://tooka.js0980420.workers.dev/" target="_blank" rel="noreferrer">
        <Image src={tookaCoverImage} alt="Tooka 開源社群圖文模板框架封面" class="w-full object-cover" />
      </a>
      <div class="p-7">
        <p class="leading-8 text-stone-300/85">
          我開源的社群圖文模板框架：用中文描述需求，AI Agent 就能生成整組 1080×1350
          的 IG 輪播圖文——文字用程式渲染、版型用模板鎖定，不跑版、不失真，還能一鍵發佈到
          Facebook、Instagram、Threads。
        </p>
        <video
          src="/videos/tooka-workflow-demo.mp4"
          controls
          preload="metadata"
          playsinline
          class="mt-5 w-full rounded-2xl border border-sky-200/80"
        ></video>
        <div class="mt-5 flex flex-wrap gap-4">
          <a
            href="https://tooka.js0980420.workers.dev/"
            target="_blank"
            rel="noreferrer"
            class="rounded-full bg-[#1688e8] px-5 py-2.5 font-semibold text-white transition hover:bg-[#0874c9]"
          >
            線上直接使用 Tooka →
          </a>
          <a
            href="https://github.com/js0980420/tooka"
            target="_blank"
            rel="noreferrer"
            class="rounded-full border border-sky-200 bg-white px-5 py-2.5 font-semibold text-[#1688e8] transition hover:border-sky-400 hover:bg-sky-50"
          >
            查看 GitHub 原始碼 →
          </a>
        </div>
      </div>
    </div>

    <SectionHeading size="md" class="mt-14">經歷與代表作品</SectionHeading>
    <ul class="mt-6 space-y-4">
      {EXPERIENCE.map((item) => <CheckItem>{item.text}</CheckItem>)}
    </ul>

    <SectionHeading size="md" class="mt-14">教學主題</SectionHeading>
    <ul class="mt-6 grid gap-3 sm:grid-cols-2">
      {AUTHOR.knowsAbout.map((topic) => (
        <li class="rounded-2xl border border-sky-200/80 bg-white/80 px-5 py-3 text-slate-700 shadow-[0_6px_20px_rgba(30,64,175,0.04)]">{topic}</li>
      ))}
    </ul>

    <Cta />
  </div>
</Base>

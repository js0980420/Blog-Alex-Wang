---
import { getCollection } from 'astro:content';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Cta from '../components/Cta.astro';
import FaqList from '../components/FaqList.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { SITE, breadcrumbSchema } from '../consts';
import { HOME_FAQS } from '../data/faqs';
import Base from '../layouts/Base.astro';

// 文章 FAQ：依文章分組，只列有 FAQ 的文章（來源同各文章頁的 FAQPage）
const posts = (await getCollection('blog'))
  .filter((post) => post.data.faqs.length > 0)
  .sort(
    (a, b) =>
      b.data.pubDate.valueOf() - a.data.pubDate.valueOf() ||
      (b.data.cmsId ?? 0) - (a.data.cmsId ?? 0),
  );

const allFaqs = [...HOME_FAQS, ...posts.flatMap((post) => post.data.faqs)];

const schema = [
  breadcrumbSchema([{ name: '首頁', item: `${SITE.url}/` }, { name: '常見問題' }]),
  {
    '@type': 'FAQPage',
    mainEntity: allFaqs.map((f) => ({
      '@type': 'Question',
      name: f.question,
      acceptedAnswer: { '@type': 'Answer', text: f.answer },
    })),
  },
];
---

<Base
  title={`常見問題總整理｜${SITE.title}`}
  description="新手學 AI 最常問的問題總整理：課程與費用、工具選擇（Claude/Codex）、Meta API 申請、自動發文設定。問題大多整理自 Threads 與 YouTube 的真實社群留言。"
  schema={schema}
>
  <div class="mx-auto max-w-3xl px-6 py-12">
    <Breadcrumbs items={[{ name: '首頁', href: '/' }, { name: '常見問題' }]} />

    <h1 class="mt-8 text-3xl font-semibold text-slate-900 md:text-4xl">常見問題總整理</h1>
    <p class="mt-6 text-lg leading-8 text-slate-700">
      這裡的問題大多來自真實社群的提問——主要是 Threads 貼文底下的留言，也有 YouTube
      留言和一對一教學學員問過的問題（見<a href="/editorial-policy/" class="text-[#1688e8] underline underline-offset-4">編輯政策</a>）。找不到你的問題的話，直接加 LINE 免費問。
    </p>

    <SectionHeading size="md" class="mt-12">課程與服務</SectionHeading>
    <div class="mt-6">
      <FaqList faqs={HOME_FAQS} />
    </div>

    <SectionHeading size="md" class="mt-14">依主題整理的文章 FAQ</SectionHeading>
    <div class="mt-6 space-y-10">
      {posts.map((post) => (
        <section>
          <h3 class="text-lg font-semibold text-slate-900">
            <a href={`/blog/${post.id}/`} class="hover:text-[#1688e8]">{post.data.title}</a>
          </h3>
          <div class="mt-4">
            <FaqList faqs={post.data.faqs} />
          </div>
          <p class="mt-3 text-sm">
            <a href={`/blog/${post.id}/`} class="text-amber-500 underline underline-offset-4 hover:text-amber-600">閱讀完整教學 →</a>
          </p>
        </section>
      ))}
    </div>

    <Cta />
  </div>
</Base>

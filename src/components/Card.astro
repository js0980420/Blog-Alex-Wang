---
// 全站共用卡片外框；hover 效果或間距調整由呼叫端用 class 傳入
interface Props {
  as?: 'div' | 'a' | 'article';
  href?: string;
  class?: string;
  /** 需要滿版內容（如影片嵌入）時設為 false，自行控制內距 */
  padded?: boolean;
}

const { as: Tag = 'div', href, class: className, padded = true } = Astro.props;
---

<Tag
  href={href}
  class:list={[
    'rounded-[1.75rem] border border-sky-200/80 bg-white/80 shadow-[0_8px_30px_rgba(30,64,175,0.06)]',
    padded && 'p-7',
    className,
  ]}
>
  <slot />
</Tag>

---
// 打勾清單項；首頁學習成果用 emerald 勾勾，其餘頁面用預設 amber
interface Props {
  as?: 'li' | 'div';
  iconClass?: string;
}

const { as: Tag = 'li', iconClass = 'text-amber-200' } = Astro.props;
---

<Tag class="flex gap-3 rounded-2xl border border-sky-200/80 bg-white/80 p-5 leading-7 text-slate-700 shadow-[0_6px_20px_rgba(30,64,175,0.04)]">
  <span class={iconClass}>✓</span>
  <slot />
</Tag>
